<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_base"
    tools:context=".MainActivity">

    <!-- 模拟手机视口容器 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:background="@color/white"
        android:elevation="8dp"
        android:importantForAccessibility="no"
        android:orientation="vertical">

        <!-- 头部区域 (Header) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white_translucent_80"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="48dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <!-- 搜索框容器 -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="16dp"
                    android:layout_weight="1">

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/bg_search_input"
                        android:fontFamily="sans-serif"
                        android:gravity="center_vertical"
                        android:hint="@string/search_hint"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:paddingStart="36dp"
                        android:paddingEnd="16dp"
                        android:textSize="14sp"
                        tools:ignore="Autofill,TouchTargetSizeCheck" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="12dp"
                        android:contentDescription="@string/search"
                        android:src="@drawable/ic_search" />

                </FrameLayout>

                <!-- 头像 -->
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_avatar"
                    android:contentDescription="@string/avatar"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_avatar_placeholder" />

            </LinearLayout>
        </FrameLayout>

        <!-- 可滚动内容区域 - 占据剩余空间 -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="16dp">

                <!-- 横向滚动卡片区域 (Trends Carousel) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:orientation="vertical">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_trend_cards"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_trend_card" />

                    <!-- 分页指示点 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginEnd="4dp"
                            android:background="@drawable/bg_dot_active" />

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="4dp"
                            android:background="@drawable/bg_dot_inactive" />

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="4dp"
                            android:background="@drawable/bg_dot_inactive" />

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/bg_dot_inactive" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 新闻列表区域 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <!-- 新闻条目 1 -->
                    <include
                        android:id="@+id/newsItem1"
                        layout="@layout/item_news_card" />

                    <!-- 新闻条目 2 -->
                    <include
                        android:id="@+id/newsItem2"
                        layout="@layout/item_news_card" />

                    <!-- 新闻条目 3 -->
                    <include
                        android:id="@+id/newsItem3"
                        layout="@layout/item_news_card" />

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- 底部导航栏 - 固定在底部 -->
        <LinearLayout
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:background="@drawable/bg_bottom_nav"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:weightSum="4">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_nav_active"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/home"
                        android:src="@drawable/ic_home" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:fontWeight="600"
                        android:text="@string/home"
                        android:textColor="@color/primary_blue"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/explore"
                    android:src="@drawable/ic_compass"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/messages"
                    android:src="@drawable/ic_message"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/profile"
                    android:src="@drawable/ic_user"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- 浮动操作按钮 (FAB) - 相对于整个屏幕定位 -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_write"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="112dp"
        android:contentDescription="@string/write_post"
        android:src="@drawable/ic_edit"
        app:backgroundTint="@color/primary_blue"
        app:elevation="6dp"
        app:fabSize="normal"
        app:tint="@color/white" />

</FrameLayout>